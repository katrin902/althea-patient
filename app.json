{
  "expo": {
    "name": "Althea",
    "slug": "althea-patient",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "althea",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.althea.patient"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FAF5ED"
      },
      "package": "com.althea.patient"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "name": "Althea",
      "shortName": "Althea",
      "description": "Your first step toward feeling better.",
      "lang": "en",
      "themeColor": "#3AABF0",
      "backgroundColor": "#FAF5ED"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
